--To update all four columns based on the new mapping details
CREATE OR REPLACE PROCEDURE staging.apply_cod_mapping()
LANGUAGE plpgsql
AS $$
DECLARE
    rec RECORD;
    sql_stmt TEXT;
BEGIN
    FOR rec IN
        SELECT DISTINCT source_column
        FROM staging.cod_mapping
    LOOP

        sql_stmt := format($f$
            UPDATE staging.orchids s
            SET %I = m.standard_value
            FROM staging.cod_mapping m
            WHERE m.source_column = %L
              AND s.%I IS NOT DISTINCT FROM m.raw_value
        $f$,
        rec.source_column,
        rec.source_column,
        rec.source_column
        );

        EXECUTE sql_stmt;

    END LOOP;
END;
$$;
CALL staging.apply_cod_mapping();
