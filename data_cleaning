SET  approached = CASE WHEN transplanted= true or procured=true or authorized=true 
						THEN true else approached END,
	authorized = CASE WHEN transplanted= true or procured=true
					THEN true else authorized END,
	procured = CASE WHEN transplanted= true THEN true else procured END
where transplanted= true or procured=true or authorized=true;

