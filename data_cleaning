-- Standardize the cause ofdeath given by OPO, UNOS along with mechanism and circumstance of death
-- To fix leading/trailing spaces, Empty Strings, Multi spaces

UPDATE staging.orchids 
SET
  cause_of_death_opo   = NULLIF(TRIM(REGEXP_REPLACE(cause_of_death_opo, '\s+', ' ', 'g')), ''),
  cause_of_death_unos  = NULLIF(TRIM(REGEXP_REPLACE(cause_of_death_unos, '\s+', ' ', 'g')), ''),
  mechanism_of_death  = NULLIF(TRIM(REGEXP_REPLACE(mechanism_of_death, '\s+', ' ', 'g')), ''),
  circumstances_of_death = NULLIF(TRIM(REGEXP_REPLACE(circumstances_of_death, '\s+', ' ', 'g')), '');

DROP TABLE if exists staging.cod_mapping;
create table if not exists staging.cod_mapping (
	source_column VARCHAR(50),
    raw_value      VARCHAR(255),
    standard_value VARCHAR(255));

