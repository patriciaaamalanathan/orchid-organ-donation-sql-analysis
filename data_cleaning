-- CREATE Final tables.
CREATE SCHEMA IF NOT EXISTS dbo;
DROP TABLE IF EXISTS dbo.opo_hospital;
Create table IF NOT EXISTS dbo.opo_hospital as
( select opo, hospitalid, count(patientid) as donors_count from staging.orchids
group by opo,hospitalid order by opo);
ALTER TABLE dbo.opo_hospital
ADD CONSTRAINT opo_hospital_pkey PRIMARY KEY (hospitalid);

DROP TABLE  IF EXISTS dbo.donor_demographics;
CREATE TABLE IF NOT EXISTS  dbo.donor_demographics as
(SELECT patientid,
age,
gender, 
race,
hospitalid,
concat(abo_bloodtype,' ',case when initcap(trim(abo_rh))='Positive' then '+' 
										when initcap(trim(abo_rh))='Negative' then '-' else NULL END
			  ) as bloodgroup ,
heightin as height,
weightkg as weight,referral_dayofweek,
referral_year,
case WHEN tissue_referral is true then 1 
WHEN tissue_referral is false then 0 END as tissue_referral,
case when eye_referral  is true then 1 
WHEN eye_referral is false then 0 END as eye_referral,
procured_year,
time_asystole,
time_brain_death,
COALESCE(time_asystole, time_brain_death) as time_of_death
from staging.orchids);

ALTER TABLE dbo.donor_demographics
ADD CONSTRAINT pk_donor_demographics
PRIMARY KEY (patientid),
ADD CONSTRAINT "fk_donor_demographics" FOREIGN KEY (hospitalid)
        REFERENCES dbo.opo_hospital (hospitalid) MATCH FULL
        ON UPDATE NO ACTION
        ON DELETE NO ACTION
        NOT VALID;

DROP TABLE IF EXISTS dbo.organ_proc_stage;
CREATE TABLE IF NOT EXISTS dbo.organ_proc_stage as
(SELECT patientid
,CASE WHEN transplanted is True then 1 
	WHEN transplanted IS False THEN 0 end as transplanted
, CASE WHEN procured  is True then 1 
	WHEN procured  is False then 0 end as procured
, CASE WHEN authorized  is True then 1 
WHEN authorized  is False then 0 end as authorized
, CASE when approached  is True then 1 
when approached  is False then 0 end as approached
,CASE WHEN transplanted IS TRUE THEN 'transplanted'
    WHEN procured IS TRUE THEN 'procured'
    WHEN authorized IS TRUE THEN 'authorized'
    WHEN approached IS TRUE THEN 'approached'
    ELSE NULL END as procurement_stage
,time_referred
,time_approached
,time_authorized
,time_procured
from staging.orchids where COALESCE(approached, FALSE)
 OR COALESCE(authorized, FALSE)
 OR COALESCE(procured, FALSE)
 OR COALESCE(transplanted, FALSE)
order by patientid);

ALTER TABLE dbo.organ_proc_stage
ADD CONSTRAINT pk_organ_proc_stage PRIMARY KEY (patientid),
ADD CONSTRAINT fk_organ_proc_stage FOREIGN KEY (patientid)
REFERENCES dbo.donor_demographics (patientid) MATCH FULL
ON UPDATE NO ACTION
ON DELETE CASCADE;

DROP TABLE  IF EXISTS dbo.patient_cod;
Create table IF NOT exists dbo.patient_cod as
(SELECT
    patientid,
    CASE
        WHEN brain_death IS TRUE THEN 1
        WHEN brain_death IS FALSE THEN 0
    END AS brain_death_f,
	cause_of_death_opo,
    cause_of_death_unos,
    mechanism_of_death,
    circumstances_of_death
FROM staging.orchids where brain_death is True
   OR ( cause_of_death_opo IS NOT NULL
     OR cause_of_death_unos IS NOT NULL
     OR mechanism_of_death IS NOT NULL
     OR circumstances_of_death IS NOT NULL)
	 order by patientid);
ALTER TABLE dbo.patient_cod
ADD CONSTRAINT pk_patient_cod PRIMARY KEY (patientid),
ADD CONSTRAINT fk_patient_cod FOREIGN KEY (patientid)
REFERENCES dbo.donor_demographics (patientid) MATCH FULL
ON UPDATE NO ACTION
ON DELETE CASCADE;

