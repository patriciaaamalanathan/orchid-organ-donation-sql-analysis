DROP TABLE IF EXISTS dbo.outcomes;
CREATE TABLE IF NOT EXISTS dbo.outcomes AS
(SELECT
    patientid,
    outcome_heart as heart,
    outcome_liver AS liver,
    outcome_kidney_left as left_kidney,
    outcome_kidney_right as right_kidney,
    outcome_lung_right as right_lung,
    outcome_lung_left as left_lung,
    outcome_intestine as intestine,
    outcome_pancreas as pancreas
FROM staging.orchids
WHERE
    COALESCE(
        outcome_heart,
        outcome_liver,
        outcome_kidney_left,
        outcome_kidney_right,
        outcome_lung_right,
        outcome_lung_left,
        outcome_intestine,
        outcome_pancreas
    ) IS NOT NULL order by patientid
);

ALTER TABLE dbo.outcomes
ADD CONSTRAINT pk_outcomes PRIMARY KEY (patientid),
ADD CONSTRAINT fk_outcomes FOREIGN KEY (patientid)
REFERENCES dbo.donor_demographics (patientid) MATCH FULL
ON UPDATE NO ACTION
ON DELETE CASCADE;
